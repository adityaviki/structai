# StructAI — environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored; `.env.example` is committed.

# --- Database -----------------------------------------------------------------
# Matches the docker-compose defaults.
DATABASE_URL=postgresql+asyncpg://structai:structai@localhost:5432/structai
DATABASE_URL_SYNC=postgresql+psycopg://structai:structai@localhost:5432/structai

# Managed schema where loaded tables live (plan §8.2). Never written outside this schema in v1.
STRUCTAI_USER_SCHEMA=structai_user

# --- LLM ----------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Local-only dev flag: opt back into raw PII sample sending to the LLM (plan §13).
# DO NOT enable in any shared environment.
STRUCTAI_ALLOW_RAW_LLM_SAMPLES=false

# --- Storage ------------------------------------------------------------------
# Local artifact root (plan §3, §13).
STRUCTAI_DATA_DIR=./data

# Upload size limit in bytes. Default 200 MB (plan §13).
STRUCTAI_MAX_UPLOAD_BYTES=209715200

# Raw-source archive retention in days (plan §13).
STRUCTAI_RETENTION_DAYS=30

# --- Worker -------------------------------------------------------------------
# Heartbeat interval (seconds) and lease length (seconds). The reaper recycles jobs
# whose lease has expired (plan §4 invariants, §6.4).
STRUCTAI_WORKER_HEARTBEAT_SECS=10
STRUCTAI_WORKER_LEASE_SECS=60
STRUCTAI_WORKER_POLL_INTERVAL_SECS=1
