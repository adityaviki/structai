# Copy to .env (or backend/.env) and edit. All vars are optional in Phase 0
# except the Postgres + Redis URLs; the anthropic key only matters once the
# import pipeline starts calling the LLM (Phase 1+).

# Postgres role must have CREATEDB privilege. The docker-compose stack in
# this repo brings up postgres on 5434 and redis on 6381; matching URLs
# below. To use a local cluster instead, switch back to e.g.
# postgresql:///postgres and redis://127.0.0.1:6379/0.
STRUCTAI_PG_URL=postgresql://structai:structai@127.0.0.1:5434/postgres
STRUCTAI_META_DB_NAME=structai_meta

# Redis URL for the arq queue + pubsub.
STRUCTAI_REDIS_URL=redis://127.0.0.1:6381/0

# Anthropic API key (Phase 1+). Leave blank in Phase 0.
# STRUCTAI_ANTHROPIC_API_KEY=

# Default model (D5a). Override per-project later in settings.
STRUCTAI_DEFAULT_MODEL=claude-sonnet-4-6

# Workspace root for documents, run logs, snapshots metadata.
# STRUCTAI_WORKSPACE=~/.local/share/structai
