# /etc/structai.env  (mode 0640, root:ubuntu)
# Loaded by structai-api.service AND structai-worker.service.

# --- Postgres ---
# From provision-db.sh output. Role must have CREATEDB privilege.
# Database in the URL is the cluster's "postgres" — the app connects there
# for CREATE/DROP DATABASE, then to STRUCTAI_META_DB_NAME for metadata.
STRUCTAI_PG_URL=postgresql://structai:REPLACE_ME@127.0.0.1:5432/postgres
STRUCTAI_META_DB_NAME=structai_meta

# --- Redis (arq queue + SSE pubsub) ---
STRUCTAI_REDIS_URL=redis://127.0.0.1:6379/0

# --- Anthropic ---
# Required for the import pipeline to actually call the LLM.
STRUCTAI_ANTHROPIC_API_KEY=REPLACE_ME

# --- Login ---
# Single shared login; there is no sign-up. Auth is enforced as soon as a
# password is set, so set one here before the site is reachable. Leave
# STRUCTAI_AUTH_SECRET unset to derive the session-signing key from the
# password (sessions then rotate automatically when the password changes).
STRUCTAI_AUTH_USERNAME=admin
STRUCTAI_AUTH_PASSWORD=REPLACE_ME
# STRUCTAI_AUTH_SECRET=

# --- Defaults ---
STRUCTAI_DEFAULT_MODEL=claude-sonnet-4-6

# Workspace root for uploaded documents and per-run logs.
STRUCTAI_WORKSPACE=/var/lib/structai

# Bind: uvicorn listens here; Caddy proxies /api/* to it.
STRUCTAI_API_HOST=127.0.0.1
STRUCTAI_API_PORT=8000
